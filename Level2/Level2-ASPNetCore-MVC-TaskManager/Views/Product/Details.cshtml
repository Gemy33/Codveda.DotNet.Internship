@* ── Views/Product/Details.cshtml ── *@
@model Product
@{
    ViewData["Title"] = Model.Name;
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-action="Index">Products</a></li>
        <li class="breadcrumb-item active">@Model.Name</li>
    </ol>
</nav>

<div class="row">
    <div class="col-lg-7">
        <div class="card border-0 shadow">
            <div class="card-header bg-primary text-white d-flex justify-content-between">
                <h4 class="mb-0">@Model.Name</h4>
                <span class="badge bg-light text-primary fs-6">@Model.Category</span>
            </div>
            <div class="card-body">
                <p class="lead">@Model.Description</p>
                <hr />
                <dl class="row">
                    <dt class="col-sm-4">Price</dt>
                    <dd class="col-sm-8 text-success fw-bold fs-5">@Model.Price.ToString("C")</dd>

                    <dt class="col-sm-4">Stock</dt>
                    <dd class="col-sm-8">@Model.Stock units</dd>

                    <dt class="col-sm-4">Availability</dt>
                    <dd class="col-sm-8">
                        @if (Model.IsAvailable)
                        {
                            <span class="badge bg-success fs-6">✔ In Stock</span>
                        }
                        else
                        {
                            <span class="badge bg-danger fs-6">✘ Out of Stock</span>
                        }
                    </dd>

                    <dt class="col-sm-4">Created</dt>
                    <dd class="col-sm-8 text-muted">@Model.CreatedAt.ToString("MMMM dd, yyyy")</dd>
                </dl>
            </div>
            <div class="card-footer d-flex gap-2">
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">
                    <i class="bi bi-pencil me-1"></i>Edit
                </a>
                <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger">
                    <i class="bi bi-trash me-1"></i>Delete
                </a>
                <a asp-action="Index" class="btn btn-outline-secondary ms-auto">
                    <i class="bi bi-arrow-left me-1"></i>Back to List
                </a>
            </div>
        </div>
    </div>
</div>
