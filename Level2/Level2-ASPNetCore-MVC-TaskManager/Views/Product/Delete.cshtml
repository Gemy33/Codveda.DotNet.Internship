@* ── Views/Product/Delete.cshtml — Confirmation page ── *@
@model Product
@{
    ViewData["Title"] = "Delete: " + Model.Name;
}

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card border-danger border-2 shadow">
            <div class="card-header bg-danger text-white">
                <h4 class="mb-0">
                    <i class="bi bi-exclamation-triangle me-2"></i>Confirm Delete
                </h4>
            </div>
            <div class="card-body">
                <p class="lead">Are you sure you want to delete this product?</p>
                <dl class="row mt-3">
                    <dt class="col-sm-4">Name</dt>
                    <dd class="col-sm-8 fw-bold">@Model.Name</dd>
                    <dt class="col-sm-4">Category</dt>
                    <dd class="col-sm-8">@Model.Category</dd>
                    <dt class="col-sm-4">Price</dt>
                    <dd class="col-sm-8 text-success">@Model.Price.ToString("C")</dd>
                    <dt class="col-sm-4">Stock</dt>
                    <dd class="col-sm-8">@Model.Stock</dd>
                </dl>
                <div class="alert alert-warning mt-3 mb-0">
                    <i class="bi bi-exclamation-circle me-2"></i>
                    <strong>This action cannot be undone.</strong>
                </div>
            </div>
            <div class="card-footer d-flex gap-2">
                @* POST to DeleteConfirmed action *@
                <form asp-action="Delete" asp-route-id="@Model.Id" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-danger">
                        <i class="bi bi-trash me-1"></i>Yes, Delete
                    </button>
                </form>
                <a asp-action="Index" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-left me-1"></i>Cancel
                </a>
            </div>
        </div>
    </div>
</div>
